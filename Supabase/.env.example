# ============================================
# CREDENCIALES SUPABASE
# Copia este archivo como .env y rellena tus valores
# ============================================
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_KEY=tu_service_key_aqui

# Conexión directa PostgreSQL (Supabase)
SUPABASE_DB_HOST=db.tu-proyecto.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=tu_db_password_aqui
SUPABASE_DB_NAME=postgres

# ============================================
# CONFIGURACIÓN MQTT
# ============================================
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=sensores/forestales

# ============================================
# CONFIGURACIÓN DETECTOR
# ============================================
VENTANA_ENTRENAMIENTO=10
UMBRAL_ANOMALIA=-0.3
MIN_SENSORS_FOR_FIRE=2
BATCH_SIZE=100
BATCH_INTERVAL=5
CYCLE_INTERVAL=30
