# ============================================
# CREDENCIALES POSTGRESQL LOCAL
# Copia este archivo como .env y rellena tus valores
# ============================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=tu_password_aqui
PG_DATABASE=fire_detection

# ============================================
# CONFIGURACIÓN MQTT
# ============================================
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=sensores/forestales

# ============================================
# CONFIGURACIÓN DETECTOR
# ============================================
VENTANA_ENTRENAMIENTO=10
UMBRAL_ANOMALIA=-0.3
MIN_SENSORS_FOR_FIRE=2
CYCLE_INTERVAL=30
